# Environment Variables for Tech4Human WhatsApp AI Finance Platform

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/tech4human_banking

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── WhatsApp Business API (Meta Graph API) ───────────────────────────────────
WHATSAPP_ACCESS_TOKEN=EAAx...
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_API_VERSION=v22.0

# ── Core Banking Integration ─────────────────────────────────────────────────
# Replace with real core banking system endpoint
CORE_BANKING_API_URL=https://api.corebanking.example.com/v1
CORE_BANKING_API_KEY=cb_api_key_...

# ── NIP / NIBSS (Nigerian Interbank Settlement System) ──────────────────────
NIBSS_API_URL=https://api.nibss-plc.com.ng/v1
NIBSS_API_KEY=nibss_key_...

# ── BVN / NIN Verification ───────────────────────────────────────────────────
BVN_VERIFICATION_URL=https://api.nibss-plc.com.ng/bvn
NIN_VERIFICATION_URL=https://api.nimc.gov.ng/nin
IDENTITY_VERIFICATION_API_KEY=id_verify_key_...

# ── SMS / OTP Provider ───────────────────────────────────────────────────────
SMS_PROVIDER_URL=https://api.smsprovider.example.com/v1
SMS_PROVIDER_API_KEY=sms_key_...
SMS_SENDER_ID=Tech4Human

# ── Fraud Detection ──────────────────────────────────────────────────────────
FRAUD_ENGINE_URL=https://api.fraudengine.example.com/v1
FRAUD_ENGINE_API_KEY=fraud_key_...

# ── Bank Branding ────────────────────────────────────────────────────────────
BANK_NAME=First Bank Nigeria
BOT_NAME=FBN Banking Assistant
SUPPORT_PHONE=+2348001234567
SUPPORT_EMAIL=support@firstbanknigeria.com

# ── Compliance / Audit ───────────────────────────────────────────────────────
AUDIT_RETENTION_YEARS=7

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
MAX_OTP_ATTEMPTS=3
OTP_EXPIRY_MINUTES=5

# ── Enterprise / Multi-Tenant ─────────────────────────────────────────────────
# Unique identifier for this bank deployment (slug, lowercase, no spaces)
# Examples: fbn, gtb, access, zenith, uba
BANK_ID=fbn
# Public-facing URL (used in Swagger server definition)
PRODUCTION_URL=https://your-bank-app.onrender.com

# ── RAG / Knowledge Base ──────────────────────────────────────────────────────
# Auto-derived from BANK_ID as: banking_kb_${BANK_ID}
# Override here only if you need a custom index name
VECTOR_INDEX_NAME=banking_kb_fbn
# Dimensions MUST match the embedding model (text-embedding-3-small = 1536)
PGVECTOR_EMBEDDING_DIM=1536
# Lightweight model for non-critical LLM calls (reranking, classification)
OPENAI_MINI_MODEL=gpt-4o-mini

# ── Azure OpenAI (Optional — overrides OpenAI provider when set) ──────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
